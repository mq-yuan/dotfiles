# Tag-gated content. Tags are set per-host in ~/.config/chezmoi/chezmoi.toml:
#
#   [data]
#   tags = ["personal", "school"]   # pick any subset
#
# Tag semantics:
#   personal — my personal desktops (home + school). Adds fastfetch + sparkle.
#   school   — the school Ubuntu workstation. Adds onedrive sync config.
#   work     — the company workstation. Adds the fish direnv hook (the
#              direnvrc itself stays available everywhere on Linux, so
#              `use_cuda` etc. are usable on any Linux host that installs
#              direnv on its own).
#
# Machines with no tags (e.g. remote GPU hosts) get the minimal base config.
#
# Note(rime): rime/custom_phrase.txt has TWO delivery stubs — Mac
# (~/Library/Rime/) and Linux native (~/.local/share/fcitx5/rime/). Both
# reference the single source at .chezmoitemplates/custom_phrase.txt, so edits
# stay in one place. The Flatpak stub was removed when this host switched to
# the APT-installed fcitx5.
{{- $tags := list }}
{{- if hasKey . "tags" }}{{ $tags = .tags }}{{ end }}

{{- if not (has "personal" $tags) }}
.config/fastfetch/
.config/sparkle/
{{- end }}

{{- if not (has "school" $tags) }}
.config/onedrive/
{{- end }}

{{- if not (has "work" $tags) }}
.config/fish/conf.d/16_direnv.fish
{{- end }}
