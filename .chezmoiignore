# Tag-gated content. Tags are set per-host in ~/.config/chezmoi/chezmoi.toml:
#
#   [data]
#   tags = ["dev", "proxy"]   # pick any subset
#
# Tag semantics:
#   dev      — a full development box (vs a light entertainment machine). Has no
#              file gating here; it drives the macOS Brewfile tier (dev hosts get
#              the heavy LaTeX/media/Lua toolchain, others a lean core set). See
#              private_dot_config/homebrew/Brewfile.tmpl.
#   proxy    — runs the Sparkle (Mihomo Party) proxy. Adds .config/sparkle/.
#   onedrive — needs the OneDrive client config (Linux has no good GUI client).
#              Adds .config/onedrive/.
#   company  — the company workstation. Like `dev`, no file gating here; it adds
#              company-only keybinds inside yazi/keymap.toml.tmpl (remote paths).
#
# Ships everywhere now (no longer tag-gated): fastfetch (cosmetic) and the
# direnv fish hook + binary (direnv is universal).
#
# Machines with no tags (e.g. remote GPU hosts) get the minimal base config.
#
# Note(rime): rime/custom_phrase.txt has TWO delivery stubs — Mac
# (~/Library/Rime/) and Linux native (~/.local/share/fcitx5/rime/). Both
# reference the single source at .chezmoitemplates/custom_phrase.txt, so edits
# stay in one place. The Flatpak stub was removed when this host switched to
# the APT-installed fcitx5.
{{- $tags := list }}
{{- if hasKey . "tags" }}{{ $tags = .tags }}{{ end }}

{{- if not (has "proxy" $tags) }}
.config/sparkle/
{{- end }}

{{- if not (has "onedrive" $tags) }}
.config/onedrive/
{{- end }}
