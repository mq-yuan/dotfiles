{{- if hasKey . "tags" }}{{ $tags = .tags }}{{ end -}}
{{- if gt (len $tags) 0 -}}
#!/usr/bin/env bash
# Ensure Homebrew exists before the brew-bundle script runs. Idempotent: exits
# early if brew is already on PATH or installed in a standard prefix. Only runs
# on tag-bearing hosts (untagged hosts render this script empty -> skipped).
set -euo pipefail

if command -v brew >/dev/null 2>&1; then
    exit 0
fi
for prefix in /opt/homebrew /usr/local /home/linuxbrew/.linuxbrew; do
    if [ -x "$prefix/bin/brew" ]; then
        exit 0
    fi
done

echo "Homebrew not found -- installing non-interactively..."
NONINTERACTIVE=1 /bin/bash -c \
    "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
{{ end -}}
