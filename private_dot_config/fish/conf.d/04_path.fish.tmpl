# $HOME/.config/fish/conf.d/04_path.fish
{{- $tags := list }}
{{- if hasKey . "tags" }}{{ $tags = .tags }}{{ end }}
{{ if eq .chezmoi.os "linux" }}
fish_add_path /home/linuxbrew/.linuxbrew/bin/
{{ else if eq .chezmoi.os "darwin" }}
fish_add_path /opt/homebrew/bin
{{ if has "dev" $tags -}}
# imagemagick-full is keg-only (the plain imagemagick formula owns the linked
# name), so its tools (magick/convert/identify) need an explicit PATH entry.
fish_add_path /opt/homebrew/opt/imagemagick-full/bin
{{ end -}}
{{ end }}
fish_add_path $HOME/bin
fish_add_path $HOME/.local/bin
