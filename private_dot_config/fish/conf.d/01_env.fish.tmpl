# $HOME/.config/fish/conf.d/01_env.fish
set --global fish_greeting "" # define your welcome message, you can set it as "" to ban it for better startup time.

# --export for bash, if you noly need it work in fish, you do not need to set --export.
set --global --export EDITOR "nvim"
set --global --export UPDATE_LOG_FILE "$HOME/.log/update.log" # set update_log_file
set --global --export XDG_CONFIG_HOME "$HOME/.config"
set --global --export fisher_path "$HOME/.config/fisher"
set --global --export CODEX_HOME "$HOME/.config/codex"

# Load sercet env
if test -f $HOME/.config/fish/.env.fish
    source $HOME/.config/fish/.env.fish
end

{{ if eq .chezmoi.os "linux" }}
# set env in Linux
# IM env vars are also exported from ~/.xprofile at X11 session start, but
# xprofile only runs once at login — shells launched outside that session
# (ssh, detached tmux server, systemd --user units) inherit nothing. Re-export
# here so every interactive fish has them regardless of how it was spawned.
set --global --export XMODIFIERS "@im=fcitx"
set --global --export QT_IM_MODULE "fcitx"
set --global --export GTK_IM_MODULE "fcitx"
# set scripts home
set --global --export SCRIPTS_HOME "$HOME/Project/scripts"
{{ end }}

# Host-specific settings (e.g. HTTP_PROXY for a local Clash on port 6355) live
# in ~/.config/fish/conf.d/99_local.fish on the machine that needs them. That
# file is NOT managed by chezmoi — it stays out of the repo on purpose.
